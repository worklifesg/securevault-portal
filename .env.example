# ── SecureVault Configuration ──────────────────────────────────
# Copy this file to .env and fill in values.
#   cp .env.example .env

# ── Server ─────────────────────────────────────────────────────
PORT=3000

# ── GitHub ─────────────────────────────────────────────────────
# Your GitHub username (required — used for fetching repos & events)
GITHUB_USERNAME=your-github-username

# Authentication: SecureVault uses `gh` CLI auth by default.
# If you prefer a personal access token instead, uncomment:
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Required token scopes: repo, read:user  (add read:org to index organization repos)

# ── Local Scanning ─────────────────────────────────────────────
# Comma-separated list of directories to scan for local projects.
# Default: your home directory (~)
# SCAN_DIRS=/home/user/projects,/home/user/work

# ── Scanner Binaries ───────────────────────────────────────────
# Extra PATH entries where scanner binaries live.
# Default: ~/.local/bin (where the install script puts them)
# SCANNER_BIN_PATH=/home/user/.local/bin
